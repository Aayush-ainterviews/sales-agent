# Copy this file to .env and fill in real values. This also lists every env var to
# set in Railway (Hissa D). Never commit the real .env — it is gitignored.

# --- required: infra ---
E2B_API_KEY=
DATABASE_URL=postgresql://postgres:pass@localhost:5432/postgres   # Railway injects its own; this is local Docker

# --- required: LLM + research providers (reach the sandbox) ---
GEMINI_API_KEY=
ORIGAMI_API_KEY=
APOLLO_API_KEY=
APIFY_TOKEN=

# --- required: auth (Clerk) ---
# Your Clerk instance's Frontend API URL (JWTs are verified against its JWKS).
# Clerk Dashboard -> API keys -> "Frontend API URL", e.g. https://your-app.clerk.accounts.dev
CLERK_JWT_ISSUER=

# --- frontend CORS: allowed browser origins (comma-separated). With direct-connect
#     the browser calls this API cross-origin, so set the REAL frontend origin(s) —
#     '*' still works but pin it in prod, e.g. https://your-app.vercel.app ---
CORS_ORIGINS=*

# --- required: send (ZeptoMail — Backend only, never the sandbox) ---
ZEPTOMAIL_API_KEY=
ZEPTOMAIL_FROM_EMAIL=
ZEPTOMAIL_FROM_NAME=Sales
# ZEPTOMAIL_API_URL=https://api.zeptomail.in/v1.1/email   # override region if not .in

# --- dev safety net: redirect ALL sends to one inbox (leave UNSET in prod) ---
SEND_OVERRIDE_TO=
